rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price >= 0 &&
             data.category in ['Plants', 'Seeds', 'Pots', 'Care'] &&
             data.images is list && data.images.size() > 0 &&
             data.stock is int && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.deliveryType in ['Delivery', 'Pickup', 'In-table'] &&
             data.contact is map && data.contact.email is string;
    }

    function isValidContact(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
             data.status in ['new', 'replied'] &&
             data.createdAt is string;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && (!('role' in incoming()) || incoming().role == 'user');
      allow update: if (isOwner(userId) && incoming().role == existing().role) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow create: if isValidContact(incoming());
      allow read, update, delete: if isAdmin();
    }
  }
}
