{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An ecommerce product (plant, seed, pot, care)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Plants", "Seeds", "Pots", "Care"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "integer" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "price", "category", "images", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "deliveryType": { "type": "string", "enum": ["Delivery", "Pickup", "In-table"] },
        "shippingAddress": { "type": "object" },
        "contact": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "deliveryType", "contact"]
    },
    "Story": {
      "title": "Story",
      "description": "A 24-hour story (social feature)",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "comments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "text": { "type": "string" },
              "createdAt": { "type": "string" }
            }
          } 
        }
      },
      "required": ["url", "type", "expiresAt"]
    },
    "Blog": {
      "title": "Blog",
      "description": "A blog post",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "author"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A user message from contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "reply": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "repliedAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "storyId": { "type": "string" }
      },
      "required": ["name", "email", "message", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Store products" },
    "/orders/{orderId}": { "schema": "Order", "description": "Store orders" },
    "/stories/{storyId}": { "schema": "Story", "description": "Store stories" },
    "/blogs/{blogId}": { "schema": "Blog", "description": "Store blog posts" },
    "/users/{userId}": { "schema": "object", "description": "User profiles" },
    "/contacts/{contactId}": { "schema": "Contact", "description": "Store user messages" }
  }
}
